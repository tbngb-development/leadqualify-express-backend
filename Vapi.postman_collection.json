      "name": "🏥 Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is OK', function () {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.status).to.eql('OK');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantName\": \"Test Company\",\n  \"name\": \"Admin User\",\n  \"email\": \"admin@testcompany.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register successful', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.success).to.be.true;",
                  "  if (res.data && res.data.token) {",
                  "    pm.collectionVariables.set('TOKEN', res.data.token);",
                  "    console.log('TOKEN saved');",
                  "  }",
                  "  if (res.data && res.data.tenant) {",
                  "    pm.collectionVariables.set('TENANT_ID', res.data.tenant.id);",
                  "    console.log('TENANT_ID saved:', res.data.tenant.id);",
                  "  }",
                  "  if (res.data && res.data.user) {",
                  "    pm.collectionVariables.set('USER_ID', res.data.user.id);",
                  "    console.log('USER_ID saved:', res.data.user.id);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/auth/login",
